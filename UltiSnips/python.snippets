
snippet pr "print"
print($1)
endsnippet

snippet ppr "pretty print"
from pprint import pprint
print($1)
endsnippet

snippet dd "dump and die"
import config.helpers as helpers
return helpers.dump($1)
endsnippet

snippet pud "start pud"
import pudb; pu.db
endsnippet

snippet pdb "start pdb"
breakpoint()
endsnippet

snippet doc "dostring"
"""
$1
"""
endsnippet
